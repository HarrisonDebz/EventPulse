<ContentPage
    x:Class="EventPulse_v1.Views.EventsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Campus Events">
    <CollectionView ItemsSource="{Binding Events}">
        <CollectionView.ItemTemplate>
            <DataTemplate>
                <Frame
                    Margin="10"
                    BackgroundColor="#1E1E1E"
                    CornerRadius="15">
                    <StackLayout>
                        <Label
                            FontAttributes="Bold"
                            FontSize="18"
                            Text="{Binding Title}" />
                        <Label FontSize="14" Text="{Binding Date}" />
                        <Label FontSize="13" Text="{Binding Description}" />
                    </StackLayout>
                </Frame>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>
</ContentPage>