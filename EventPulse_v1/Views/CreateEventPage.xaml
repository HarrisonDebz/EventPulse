<ContentPage
    x:Class="EventPulse_v1.Views.CreateEventPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Create Event">


    <ScrollView>
        <VerticalStackLayout Padding="20">
            <Entry Placeholder="Event Title" Text="{Binding Title}" />
            <Editor Placeholder="Description" Text="{Binding Description}" />
            <DatePicker Date="{Binding Date}" />
            <Entry Placeholder="Venue" Text="{Binding Venue}" />
            <Button Command="{Binding CreateEventCommand}" Text="Create Event" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>